{
  "name": "construction-management",
  "version": "1.0.0",
  "private": true,
  "description": "Velocity Nexus - Construction Management Orchestration Platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "db:generate": "prisma generate --schema=packages/db/prisma/schema.prisma",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "prisma": "6.2.1",
    "prettier": "latest",
    "turbo": "latest"
  },
  "engines": {
    "node": "20.x"
  },
  "packageManager": "npm@10.5.0",
  "dependencies": {
    "@prisma/client": "^6.2.1"
  }
}
